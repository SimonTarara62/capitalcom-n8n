{
  "name": "n8n-nodes-capitalcom",
  "version": "0.1.1",
  "description": "Unofficial, in-development (alpha) n8n community node for the Capital.com Open API — market data, accounts, watchlists, trading, and WebSocket streaming.",
  "keywords": [
    "n8n-community-node-package",
    "capital.com",
    "trading",
    "cfd",
    "market-data",
    "finance"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/SimonTarara62/capitalcom-n8n",
  "author": {
    "name": "Simon Tarara"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimonTarara62/capitalcom-n8n.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials transport --write",
    "lint": "eslint nodes credentials transport package.json --no-error-on-unmatched-pattern",
    "lintfix": "eslint nodes credentials transport package.json --fix --no-error-on-unmatched-pattern",
    "lint:prepublish": "eslint nodes credentials transport package.json --no-error-on-unmatched-pattern -c .eslintrc.prepublish.js",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "prepublishOnly": "npm run build && npm run lint:prepublish"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CapitalComApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CapitalCom/CapitalCom.node.js",
      "dist/nodes/CapitalComTrigger/CapitalComTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.21",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.70.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
